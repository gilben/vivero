{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "REPLACE_WITH_YOUR_CONNECTION_STRING"
  },
  "Jwt": {
    "SecretKey": "REPLACE_WITH_SECURE_SECRET_MIN_32_CHARS",
    "Issuer": "pj6-api",
    "Audience": "pj6-client",
    "ExpirationMinutes": 60
  }
}