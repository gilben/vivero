VITE_API_BASE_URL=http://localhost:5000/api
# true = login/recuperación simulados en el front (sin backend)
VITE_AUTH_MOCK=true

# Chat IA — proveedor: mock | claude | openai | gemini
# ADVERTENCIA: una API key aquí es visible para cualquier visitante del sitio.
# Solo para desarrollo/demo; en producción el chat pasa por el backend (ST-AI-01).
VITE_AI_PROVIDER=mock
VITE_AI_API_KEY=
# Modelo opcional (defaults: claude-opus-4-8 / gpt-4o-mini / gemini-3.5-flash)
VITE_AI_MODEL=
# Correo que recibe las solicitudes de cotización
VITE_QUOTE_EMAIL=ventas@pj6vivero.com
